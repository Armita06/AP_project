<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.LoginController">
   <padding>
      <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
   </padding>

   <Label text="ورود به سیستم">
      <font>
         <Font name="System Bold" size="18.0" />
      </font>
      <VBox.margin>
         <Insets bottom="10.0" />
      </VBox.margin>
   </Label>

   <TextField fx:id="usernameField" promptText="نام کاربری" />
   <PasswordField fx:id="passwordField" promptText="رمز عبور" />

   <Button mnemonicParsing="false" onAction="#onLoginButtonClick" prefWidth="100.0" text="ورود" />

   <Hyperlink onAction="#onRegisterLinkClick" text="حساب کاربری ندارید؟ ثبت‌نام کنید" />

   <Label fx:id="messageLabel" textFill="RED" wrapText="true">
      <VBox.margin>
         <Insets top="10.0" />
      </VBox.margin>
   </Label>
</VBox>