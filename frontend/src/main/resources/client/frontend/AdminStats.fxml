<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane nodeOrientation="RIGHT_TO_LEFT" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.AdminStatsController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="گزارش‌های آماری سیستم" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#onBackClick" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="بازگشت به پنل مدیریت" />
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="30.0" style="-fx-padding: 40; -fx-background-color: #ecf0f1;">
            <Label fx:id="messageLabel" textFill="RED">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>

            <GridPane alignment="CENTER" hgap="30.0" vgap="30.0">
                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-border-color: #3498db; -fx-border-width: 0 0 5 0; -fx-border-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="تعداد کل کاربران" textFill="#7f8c8d">
                        <font><Font name="System Bold" size="16.0" /></font>
                    </Label>
                    <Label fx:id="totalUsersLabel" text="..." textFill="#3498db">
                        <font><Font name="System Bold" size="30.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-border-color: #2ecc71; -fx-border-width: 0 0 5 0; -fx-border-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="کل آگهی‌ها" textFill="#7f8c8d">
                        <font><Font name="System Bold" size="16.0" /></font>
                    </Label>
                    <Label fx:id="totalAdsLabel" text="..." textFill="#2ecc71">
                        <font><Font name="System Bold" size="30.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-border-color: #f39c12; -fx-border-width: 0 0 5 0; -fx-border-radius: 10;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="آگهی‌های در انتظار بررسی" textFill="#7f8c8d">
                        <font><Font name="System Bold" size="16.0" /></font>
                    </Label>
                    <Label fx:id="pendingAdsLabel" text="..." textFill="#f39c12">
                        <font><Font name="System Bold" size="30.0" /></font>
                    </Label>
                </VBox>

                <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-border-color: #e74c3c; -fx-border-width: 0 0 5 0; -fx-border-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="تعداد کل گزارش‌ها" textFill="#7f8c8d">
                        <font><Font name="System Bold" size="16.0" /></font>
                    </Label>
                    <Label fx:id="totalReportsLabel" text="..." textFill="#e74c3c">
                        <font><Font name="System Bold" size="30.0" /></font>
                    </Label>
                </VBox>
            </GridPane>
        </VBox>
    </center>
</BorderPane>
