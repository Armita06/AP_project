<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane nodeOrientation="RIGHT_TO_LEFT" prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.ChatController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="سیستم پیام‌رسانی" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#onBackClick" style="-fx-background-color: #95a5a6; -fx-text-fill: white;" text="بازگشت به داشبورد" />
        </HBox>
    </top>
    <center>
        <SplitPane dividerPositions="0.3" style="-fx-background-color: #f5f6fa;">
            <!-- سمت راست: لیست گفت‌وگوها -->
            <VBox spacing="10.0" style="-fx-padding: 10; -fx-background-color: white;">
                <Label text="گفت‌وگوهای من">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <Label fx:id="conversationsMessageLabel" textFill="RED" wrapText="true" />
                <ListView fx:id="conversationsList" VBox.vgrow="ALWAYS" style="-fx-border-color: #bdc3c7; -fx-border-radius: 5;" />
            </VBox>

            <!-- سمت چپ: محیط چت -->
            <VBox spacing="10.0" style="-fx-padding: 10;">
                <HBox alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                    <Label fx:id="chatWithLabel" text="لطفاً یک گفت‌وگو را انتخاب کنید" textFill="#7f8c8d">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Label>
                </HBox>

                <ScrollPane fx:id="messagesScrollPane" fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="messagesContainer" spacing="15.0" style="-fx-padding: 15;" />
                </ScrollPane>

                <HBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                    <TextField fx:id="messageInput" promptText="پیام خود را بنویسید..." HBox.hgrow="ALWAYS" disable="true">
                        <font>
                            <Font size="14.0" />
                        </font>
                    </TextField>
                    <Button fx:id="sendButton" mnemonicParsing="false" onAction="#onSendMessageClick" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="ارسال پیام" disable="true">
                        <font>
                            <Font name="System Bold" size="14.0" />
                        </font>
                    </Button>
                </HBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
