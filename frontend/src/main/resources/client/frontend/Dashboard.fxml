<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.DashboardController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label fx:id="welcomeLabel" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="adminPanelButton" mnemonicParsing="false" onAction="#onAdminPanelClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="ЩҫЩҶЩ„ Щ…ШҜЫҢШұЫҢШӘ" visible="false" managed="false" />
            <Button mnemonicParsing="false" onAction="#onMyAdsClick" text="ШўЪҜЩҮЫҢвҖҢЩҮШ§ЫҢ Щ…ЩҶ" />
            <Button mnemonicParsing="false" onAction="#onCreateAdClick" text="Ш«ШЁШӘ ШўЪҜЩҮЫҢ Ш¬ШҜЫҢШҜ" />
            <Button mnemonicParsing="false" onAction="#onMessagesClick" text="ЩҫЫҢШ§Щ…вҖҢЩҮШ§" />
            <Button mnemonicParsing="false" onAction="#onBookmarksClick" text="Ш№Щ„Ш§ЩӮЩҮвҖҢЩ…ЩҶШҜЫҢвҖҢЩҮШ§" />
            <Button mnemonicParsing="false" onAction="#onLogoutClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Ш®ШұЩҲШ¬" />
        </HBox>
    </top>
    <left>
        <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #f5f6fa; -fx-padding: 20;">
            <Label text="Ш¬ШіШӘШ¬ЩҲ ЩҲ ЩҒЫҢЩ„ШӘШұ">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>
            <TextField fx:id="searchField" promptText="Ъ©Щ„Щ…ЩҮ Ъ©Щ„ЫҢШҜЫҢ ШҜШұ Ш№ЩҶЩҲШ§ЩҶ ЩҲ ШӘЩҲШ¶ЫҢШӯШ§ШӘ" />
            <TextField fx:id="categoryField" promptText="ШҜШіШӘЩҮвҖҢШЁЩҶШҜЫҢ" />
            <TextField fx:id="cityField" promptText="ШҙЩҮШұ" />
            <TextField fx:id="minPriceField" promptText="ШӯШҜШ§ЩӮЩ„ ЩӮЫҢЩ…ШӘ (ШӘЩҲЩ…Ш§ЩҶ)" />
            <TextField fx:id="maxPriceField" promptText="ШӯШҜШ§Ъ©Ш«Шұ ЩӮЫҢЩ…ШӘ (ШӘЩҲЩ…Ш§ЩҶ)" />
            <ComboBox fx:id="sortComboBox" prefWidth="210.0" promptText="Щ…ШұШӘШЁвҖҢШіШ§ШІЫҢ" />
            <Button mnemonicParsing="false" onAction="#onSearchClick" prefWidth="210.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="Ш§Ш№Щ…Ш§Щ„ ЩҒЫҢЩ„ШӘШұ" />
            <Button mnemonicParsing="false" onAction="#onClearFiltersClick" prefWidth="210.0" text="ЩҫШ§Ъ© Ъ©ШұШҜЩҶ ЩҒЫҢЩ„ШӘШұЩҮШ§" />
            <Label fx:id="errorLabel" textFill="RED" wrapText="true" />
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <FlowPane fx:id="adsContainer" hgap="20.0" style="-fx-padding: 20;" vgap="20.0" />
        </ScrollPane>
    </center>
</BorderPane>