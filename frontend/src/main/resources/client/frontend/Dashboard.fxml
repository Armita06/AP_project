<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.control.ScrollPane?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.DashboardController">
    <top>

        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label fx:id="welcomeLabel" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="adminPanelButton" mnemonicParsing="false" onAction="#onAdminPanelClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="پنل مدیریت" visible="false" managed="false" />
            <Button mnemonicParsing="false" onAction="#onMyAdsClick" text="آگهی‌های من" />
            <Button mnemonicParsing="false" onAction="#onCreateAdClick" text="ثبت آگهی جدید" />
            <Button mnemonicParsing="false" onAction="#onMessagesClick" text="پیام‌ها" />
            <Button mnemonicParsing="false" onAction="#onProfileClick" text="پروفایل من" />
            <Button mnemonicParsing="false" onAction="#onBookmarksClick" text="علاقه‌مندی‌ها" />
            <Button mnemonicParsing="false" onAction="#onLogoutClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="خروج" />
        </HBox>
    </top>
    <left>
        <VBox prefWidth="250.0" spacing="15.0" style="-fx-background-color: #f5f6fa; -fx-padding: 20;">
            <Label text="جستجو و فیلتر">
                <font>
                    <Font name="System Bold" size="16.0" />
                </font>
            </Label>
            <TextField fx:id="searchField" promptText="کلمه کلیدی در عنوان و توضیحات" />
            <TextField fx:id="categoryField" promptText="دسته‌بندی" />
            <TextField fx:id="cityField" promptText="شهر" />
            <TextField fx:id="minPriceField" promptText="حداقل قیمت (تومان)" />
            <TextField fx:id="maxPriceField" promptText="حداکثر قیمت (تومان)" />
            <ComboBox fx:id="sortComboBox" prefWidth="210.0" promptText="مرتب‌سازی" />
            <Button mnemonicParsing="false" onAction="#onSearchClick" prefWidth="210.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="اعمال فیلتر" />
            <Button mnemonicParsing="false" onAction="#onClearFiltersClick" prefWidth="210.0" text="پاک کردن فیلترها" />
            <Label fx:id="errorLabel" textFill="RED" wrapText="true" />
        </VBox>
    </left>
    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <FlowPane fx:id="adsContainer" hgap="20.0" style="-fx-padding: 20;" vgap="20.0" />
        </ScrollPane>
    </center>
</BorderPane>