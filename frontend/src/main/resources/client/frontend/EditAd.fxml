<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" nodeOrientation="RIGHT_TO_LEFT" prefHeight="600.0" prefWidth="500.0" spacing="15.0" style="-fx-padding: 30; -fx-background-color: #f5f6fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.EditAdController">
    <Label text="ویرایش آگهی">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>
    <VBox spacing="5.0">
        <Label text="عنوان آگهی *" />
        <TextField fx:id="titleField" />
    </VBox>
    <VBox spacing="5.0">
        <Label text="دسته‌بندی *" />
        <TextField fx:id="categoryField" />
    </VBox>
    <VBox spacing="5.0">
        <Label text="شهر *" />
        <TextField fx:id="cityField" />
    </VBox>
    <VBox spacing="5.0">
        <Label text="قیمت (تومان) *" />
        <TextField fx:id="priceField" />
    </VBox>
    <VBox spacing="5.0">
        <Label text="توضیحات" />
        <TextArea fx:id="descriptionField" prefRowCount="4" wrapText="true" />
    </VBox>
    <VBox spacing="5.0">
        <Label text="عکس آگهی (تغییر عکس فعلی)" />
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Button mnemonicParsing="false" onAction="#onSelectImageClick" style="-fx-background-color: #bdc3c7;" text="انتخاب عکس جدید" />
            <Label fx:id="imageNameLabel" text="عکس جدیدی انتخاب نشده است" textFill="GRAY" />
        </HBox>
    </VBox>
    <Label fx:id="messageLabel" wrapText="true" />
    <HBox alignment="CENTER" spacing="15.0">
        <Button mnemonicParsing="false" onAction="#onSubmitClick" prefWidth="120.0" style="-fx-background-color: #3498db; -fx-text-fill: white;" text="ذخیره تغییرات" />
        <Button mnemonicParsing="false" onAction="#onCancelClick" prefWidth="120.0" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" text="انصراف" />
    </HBox>
</VBox>
