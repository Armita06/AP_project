<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="350.0" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.frontend.controller.RegisterController">
    <padding>
        <Insets bottom="20.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <Label text="ثبت‌نام در سامانه دست‌دوم">
        <font>
            <Font name="System Bold" size="18.0" />
        </font>
        <VBox.margin>
            <Insets bottom="10.0" />
        </VBox.margin>
    </Label>

    <TextField fx:id="nameField" promptText="نام و نام خانوادگی" />
    <TextField fx:id="usernameField" promptText="نام کاربری" />
    <PasswordField fx:id="passwordField" promptText="رمز عبور" />
    <TextField fx:id="phoneField" promptText="شماره تماس" />
    <TextField fx:id="emailField" promptText="ایمیل" />

    <Button mnemonicParsing="false" onAction="#onRegisterButtonClick" prefWidth="100.0" text="ثبت‌نام" />

    <Hyperlink onAction="#onLoginLinkClick" text="قبلاً ثبت‌نام کرده‌اید؟ ورود" />

    <Label fx:id="messageLabel" textFill="RED" wrapText="true">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
    </Label>
</VBox>